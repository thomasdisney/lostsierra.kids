{
  "builds": [
    {
      "src": "portal/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "css/**",
      "use": "@vercel/static"
    },
    {
      "src": "js/**",
      "use": "@vercel/static"
    },
    {
      "src": "images/**",
      "use": "@vercel/static"
    },
    {
      "src": "photos/**",
      "use": "@vercel/static"
    },
    {
      "src": "logos/**",
      "use": "@vercel/static"
    },
    {
      "src": "favicon/**",
      "use": "@vercel/static"
    },
    {
      "src": "bulletin-board/**",
      "use": "@vercel/static"
    },
    {
      "src": "site.webmanifest",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/portal/(.*)", "dest": "/portal/$1" },
    { "src": "/(css|js|images|photos|logos|favicon|bulletin-board)/(.*)", "dest": "/$1/$2" },
    { "src": "/site.webmanifest", "dest": "/site.webmanifest" },
    { "src": "/_next/(.*)", "dest": "/portal/_next/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/portal/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
